<!DOCTYPE html>
<html class="light" lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
		<title>
			{% block title %}Airbnb
			{% endblock %}
		</title>
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&amp;family=Inter:wght@100..900&amp;display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
		<script id="tailwind-config">
			tailwind.config = {
darkMode: "class",
theme: {
extend: {
"colors": {
"primary-fixed-dim": "#ffb2b6",
"error-container": "#ffdad6",
"outline-variant": "#e5bdbe",
"secondary-fixed-dim": "#5bdacc",
"on-surface": "#281718",
"on-error-container": "#93000a",
"secondary": "#006a62",
"on-primary-fixed": "#40000d",
"surface-container-high": "#ffe1e2",
"surface-container-low": "#fff0f0",
"surface-tint": "#be0038",
"surface-container-highest": "#fbdbdc",
"on-tertiary-container": "#f6fff6",
"surface-dim": "#f2d3d3",
"background": "#fff8f7",
"primary-container": "#e21e4a",
"inverse-surface": "#3f2b2c",
"on-primary-fixed-variant": "#920029",
"on-background": "#281718",
"on-secondary-fixed": "#00201d",
"on-secondary-fixed-variant": "#005049",
"inverse-on-surface": "#ffedec",
"on-primary-container": "#fffbff",
"outline": "#906f70",
"on-primary": "#ffffff",
"surface": "#fff8f7",
"primary": "#ba0036",
"tertiary": "#006a45",
"on-secondary-container": "#007168",
"surface-container-lowest": "#ffffff",
"on-surface-variant": "#5c3f41",
"surface-variant": "#fbdbdc",
"surface-container": "#ffe9e9",
"secondary-container": "#7af7e8",
"on-secondary": "#ffffff",
"tertiary-fixed": "#80f9bd",
"on-tertiary-fixed-variant": "#005234",
"inverse-primary": "#ffb2b6",
"tertiary-container": "#008558",
"error": "#ba1a1a",
"surface-bright": "#fff8f7",
"on-error": "#ffffff",
"secondary-fixed": "#7af7e8",
"on-tertiary-fixed": "#002113",
"tertiary-fixed-dim": "#62dca3",
"primary-fixed": "#ffdada",
"on-tertiary": "#ffffff"
},
"borderRadius": {
"DEFAULT": "0.25rem",
"lg": "0.5rem",
"xl": "0.75rem",
"full": "9999px"
},
"spacing": {
"xs": "4px",
"base": "8px",
"sm": "12px",
"md": "16px",
"xxl": "48px",
"xl": "32px",
"margin-mobile": "24px",
"container-max": "1280px",
"lg": "24px",
"gutter": "24px"
},
"fontFamily": {
"display-lg": ["Geist"],
"body-md": ["Inter"],
"body-lg": ["Inter"],
"headline-md": ["Geist"],
"label-caps": ["Inter"],
"label-bold": ["Inter"],
"headline-sm": ["Geist"],
"body-sm": ["Inter"],
"display-lg-mobile": ["Geist"]
},
"fontSize": {
"display-lg": [
"48px", {
"lineHeight": "56px",
"letterSpacing": "-0.02em",
"fontWeight": "700"
}
],
"body-md": [
"16px", {
"lineHeight": "24px",
"fontWeight": "400"
}
],
"body-lg": [
"18px", {
"lineHeight": "28px",
"fontWeight": "400"
}
],
"headline-md": [
"32px", {
"lineHeight": "36px",
"fontWeight": "600"
}
],
"label-caps": [
"12px", {
"lineHeight": "16px",
"letterSpacing": "0.05em",
"fontWeight": "800"
}
],
"label-bold": [
"14px", {
"lineHeight": "18px",
"fontWeight": "600"
}
],
"headline-sm": [
"22px", {
"lineHeight": "26px",
"fontWeight": "600"
}
],
"body-sm": [
"14px", {
"lineHeight": "20px",
"fontWeight": "400"
}
],
"display-lg-mobile": [
"32px", {
"lineHeight": "40px",
"letterSpacing": "-0.01em",
"fontWeight": "700"
}
]
}
}
}
}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.hide-scrollbar::-webkit-scrollbar {
				display: none;
			}
			.hide-scrollbar {
				-ms-overflow-style: none;
				scrollbar-width: none;
			}
			.shadow-pill {
				shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
			}
			.property-card-shadow:hover {
				box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
			}
		</style>
		{% block stylesheets %}{% endblock %}
		{% block javascripts %}{% endblock %}
	</head>
	<body class="bg-background text-on-surface font-body-md text-body-md overflow-x-hidden"> {% block body %}{% endblock %}
		</body>
	</html>
