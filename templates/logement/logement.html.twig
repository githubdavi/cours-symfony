{% extends "layout/base.html.twig" %}

{% block title %}
	{{ property.title }}
{% endblock %}

{% block content %}
	<main
		class="max-w-container-max mx-auto px-margin-mobile md:px-lg lg:px-xxl py-lg">
		<!-- Title & Action Bar -->
		<section class="mb-lg">
			<div class="flex flex-col md:flex-row md:items-end justify-between gap-md">
				<div>
					<h1 class="font-headline-md text-headline-md text-on-surface mb-xs">{{ property.address.city }}</h1>
					<div class="flex items-center flex-wrap gap-sm text-body-sm font-label-bold">
						<div class="flex items-center gap-xs">
							<span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
							<span>4,92</span>
							<span class="text-on-surface-variant font-body-sm underline ml-xs">128 commentaires</span>
						</div>
						<span>·</span>
						<div class="flex items-center gap-xs">
							<span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
							<span>Coup de cœur voyageurs</span>
						</div>
						<span>·</span>
						<span class="underline">{{ property.address.city }},
							{{ property.address.country }}</span>
					</div>
				</div>
				<div class="flex items-center gap-md">
					<button class="flex items-center gap-xs hover:bg-surface-container-low px-sm py-xs rounded-lg transition-colors underline font-label-bold">
						<span class="material-symbols-outlined text-[18px]">share</span>
						<span>Partager</span>
					</button>
					<button class="flex items-center gap-xs hover:bg-surface-container-low px-sm py-xs rounded-lg transition-colors underline font-label-bold">
						<span class="material-symbols-outlined text-[18px]">favorite</span>
						<span>Enregistrer</span>
					</button>
				</div>
			</div>
		</section>
		<!-- Photo Gallery Grid -->
		<section class="mb-xxl overflow-hidden rounded-xl h-[400px] md:h-[500px] grid grid-cols-4 grid-rows-2 gap-base">
			<div class="col-span-4 md:col-span-2 row-span-2 relative group cursor-pointer overflow-hidden">
				<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="A breathtaking luxury villa in Saint-Tropez featuring a massive infinity pool that blends seamlessly into the Mediterranean Sea. The architecture is ultra-modern with clean white lines, floor-to-ceiling glass walls, and a minimalist limestone patio. Soft golden hour lighting casts warm reflections on the water, creating a serene and premium holiday atmosphere consistent with the high-end Airbnb aesthetic." src="https://lh3.googleusercontent.com/aida/AP1WRLs2J70MFrr6H_SLiK2tdOO36IMdSVwDOGn7E20pJ5BONmQ3yIJiHFwxRcc6dB3iGahHqL-Uxvmo7k93j3g8eIK13KhQR1XNlf7Cz5eJg2HppdHhpUheJnIEjR8h2zKurFoJyYRKUWEGniOdDqEm6ghrBnLg8FOUxE--H3hyxsjNrlToTaEKpkQkmFAKctqUESyd8lBnjJkV-2mV3IXyM0WvFUq181_4kWLVeAnQTD9SFneB4QxDLB2-MR0"/>
			</div>
			<div class="hidden md:block col-span-1 row-span-1 relative group cursor-pointer overflow-hidden">
				<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="A bright, modern bedroom inside a luxury villa with a king-sized bed dressed in high-thread-count white linens. Large windows offer a stunning view of a lush private garden and the ocean beyond. The room is decorated in a minimalist style with natural wood accents and soft ambient lighting, evoking a sense of calm and elite comfort." src="https://lh3.googleusercontent.com/aida/AP1WRLuZcp-8euIPV64qKFOfncRtWBk1u4PQ7z1zYJIrLaoqRaOmtozqzk2d0NobIL93DBzpp2shG33jJ-887rlKf4PvSskVCQDHemNzMZsoWyJ8mtkWxPQA0y8CaW1AEV5XipB-s4sE8kujoB-WzZ7nrnsC3wer3MSHm6pcOMVQ--UkPo2SNeu2TUtXJICRVfq6QnVf8Or8FuzUX4zlEVGrl-v4mUfEAyZBRaxoe9uw4yxW3t2ElOJMVcvDvt8X"/>
			</div>
			<div class="hidden md:block col-span-1 row-span-1 relative group cursor-pointer overflow-hidden">
				<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="A sophisticated chef's kitchen featuring integrated state-of-the-art appliances, dark marble countertops, and a minimalist island with bar seating. The design is sleek and functional, illuminated by recessed spotlights and natural light from a side terrace, emphasizing the premium quality of the property's amenities." src="https://lh3.googleusercontent.com/aida/AP1WRLvI015uEq2tbtMntBEW4mzSKA9t06-f-Ercas3A3aNneG8RiJLCn00T4maiAkpomTrYqlgn7nYxYatgZeRB3hjNFS0hrlOiAsZRXnDeGBghYxz5GsqT7ByXaaGKiUwOaVmjSAZmoRB3gPxCMm3Q4wRpNlXhaAhphcWyl-Ob43h_Pq8CFbWIJySE_WRMEoisd9psU6u4MqjdwE-r5qsIVzDtjlxmBFLPAvQODnStthWivrXsJVuD5eJ_Uytn"/>
			</div>
			<div class="hidden md:block col-span-1 row-span-1 relative group cursor-pointer overflow-hidden">
				<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="A spa-like bathroom with a deep freestanding soaking tub positioned next to a large window overlooking the sea. The walls are finished in smooth microcement, complemented by warm wooden shelving and minimalist chrome fixtures. The scene is bright and airy, capturing the essence of luxury hospitality." src="https://lh3.googleusercontent.com/aida/AP1WRLtPnNgUzHkjb9Az3VLyf_5XeaE7EMtRWdQlSwEYXYR0AVIoS0LVDN88uLFv5KWn0b9FXfFhBzHdkx4XoLr4PIoKYohAMN2ql7NEMJPhnOObf11SPf27EIFJqfJ0kBiy6VO6noXwtB9XDgVLmyPI_pTV0i1h5f9FJT1ssnSL4VYAJQO8AF_Z54zoRowKKBIooIg6KUaqaH5RfEdIl7kAzIBVi91eRc-M_xWBaJShPCbIaavaCF0FpN2ASRoz"/>
			</div>
			<div class="hidden md:block col-span-1 row-span-1 relative group cursor-pointer overflow-hidden">
				<img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="A sunset view from the villa's expansive terrace, featuring designer outdoor lounge chairs and a modern fire pit. The sky is painted in shades of pink and orange, reflecting beautifully on the infinity pool surface. This evocative scene highlights the villa's outdoor living experience in a prestigious Mediterranean setting." src="https://lh3.googleusercontent.com/aida/AP1WRLtZAbRFwUYdsUYY8xuyF-YsqlLvcBtrSg0e80KubHIiwiWr3gLhkm0jwH-zg--xeXDKZV6NqLbNvM-ywg-HWN-B6gGlaIu8gjRyjJSZWXmFjDhufewwriHxi0XyyiTHCiW4D6bIFBQ-HucprfVNbYeSMR_EZkCpcOv2lATntXhfWj4PWniHZKGGNkBbkRCTzP1kiEDXACl-aK3_2e7wB9SHcRx_CJb2ymEJhTIXji3gcuGYJoPH3qmho5E"/>
			</div>
		</section>
		<div
			class="flex flex-col lg:flex-row gap-xxl">
			<!-- Main Content (2/3) -->
			<div
				class="flex-1 lg:w-2/3">
				<!-- Host & Info -->
				<div class="pb-lg border-b border-outline-variant flex justify-between items-center">
					<div>
						<h2 class="font-headline-sm text-headline-sm text-on-surface">Logement entier :
							{{ property.propertyType }}</h2>
						<p class="text-body-md text-on-surface-variant">{{ property.maxGuests }}
							voyageurs ·
							{{ property.bedrooms }}
							chambres ·
							{{ property.beds }}
							lits ·
							{{ property.bathrooms }}
							salles de bain</p>
					</div>
					<div class="relative">
						<div class="w-14 h-14 rounded-full overflow-hidden border border-outline-variant">
							<img class="w-full h-full object-cover" data-alt="A professional portrait of a friendly and elegant female host, Elena, against a soft blurred interior background. She has a warm smile, representing the trust and hospitality central to the brand's identity. The image is clean and well-lit in a modern light-mode style." src="https://lh3.googleusercontent.com/aida/AP1WRLvN3gbtUs-45zIkdwp1ZoGoV4Ei6wShEX2nj-2TmCYWW1-G_SjJUFQmxTok5LCrqHvVMjopk4QfEkl-ODEm65u0a14_EaUHuo25iCLg5_yWyX_OrclPgPJSdnhnvwHuy6w2irw9ZX2WtBSR2FGD1CChqw6fHmQ6zvPKCIogkkbwyzPCCLK9dOz28CYdjEZrte-ZLU58o5k1yk5_lALNgzEKNjgEL0YVfCdO3HNFL3zDCri2brgWWNYVzojQ"/>
						</div>
						<div class="absolute -bottom-1 -right-1 bg-primary text-white rounded-full p-[2px] flex items-center justify-center">
							<span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
						</div>
					</div>
				</div>
				<!-- Proposé par Elena section -->
				<div class="py-lg border-b border-outline-variant">
					<div class="flex gap-lg items-start">
						<span class="material-symbols-outlined text-[28px] text-on-surface">badge</span>
						<div>
							<p class="font-label-bold text-on-surface">Proposé par Elena</p>
							<p class="text-body-sm text-on-surface-variant">Superhôte · 8 ans d'expérience</p>
						</div>
					</div>
				</div>
				<!-- Highlights -->
				<div class="py-lg border-b border-outline-variant flex flex-col gap-lg">
					<div class="flex gap-lg">
						<span class="material-symbols-outlined text-[28px] text-on-surface">door_open</span>
						<div>
							<p class="font-label-bold text-on-surface">Arrivée autonome</p>
							<p class="text-body-sm text-on-surface-variant">Vous pouvez entrer dans les lieux avec une boîte à clé sécurisée.</p>
						</div>
					</div>
					<div class="flex gap-lg">
						<span class="material-symbols-outlined text-[28px] text-on-surface">workspace_premium</span>
						<div>
							<p class="font-label-bold text-on-surface">Elena est Superhôte</p>
							<p class="text-body-sm text-on-surface-variant">Les Superhôtes sont des hôtes expérimentés qui bénéficient de très bonnes évaluations.</p>
						</div>
					</div>
					<div class="flex gap-lg">
						<span class="material-symbols-outlined text-[28px] text-on-surface">event_available</span>
						<div>
							<p class="font-label-bold text-on-surface">Annulation gratuite avant le 15 juil.</p>
						</div>
					</div>
				</div>
				<!-- Description -->
				<div class="py-lg border-b border-outline-variant">
					<p class="text-body-md text-on-surface leading-relaxed">
						Située sur les hauteurs prestigieuses de Saint-Tropez, cette villa d'architecte offre une vue panoramique imprenable sur la baie. Conçue pour fusionner le confort moderne avec l'élégance méditerranéenne, la propriété dispose d'espaces de vie ouverts, d'une piscine à débordement chauffée et de jardins paysagers luxuriants.
						<br/><br/>
						Chaque chambre est une suite privée avec accès direct aux terrasses. Profitez de soirées inoubliables au bord de l'eau ou détendez-vous dans le salon home cinéma...
					</p>
					<button class="mt-md font-label-bold underline flex items-center gap-xs">
						En savoir plus
						<span class="material-symbols-outlined text-[18px]">chevron_right</span>
					</button>
				</div>

			</div>
			<!-- Sidebar (1/3) -->
			<aside class="lg:w-1/3 relative">
				<div class="sticky top-24 border border-outline-variant rounded-xl p-lg shadow-xl bg-white flex flex-col gap-md">
					<div class="flex justify-between items-end">
						<div>
							<span class="font-headline-sm text-headline-sm">1 250 €</span>
							<span class="text-body-md text-on-surface-variant">
								par nuit</span>
						</div>
						<div class="flex items-center gap-xs text-body-sm font-label-bold">
							<span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">star</span>
							<span>4,92 · 128 commentaires</span>
						</div>
					</div>
					<div class="border border-outline-variant rounded-xl overflow-hidden">
						<div class="flex border-b border-outline-variant">
							<div class="flex-1 p-sm border-r border-outline-variant cursor-pointer hover:bg-surface-container-lowest">
								<p class="font-label-caps text-on-surface text-[10px]">ARRIVÉE</p>
								<p class="text-body-sm">22/07/2024</p>
							</div>
							<div class="flex-1 p-sm cursor-pointer hover:bg-surface-container-lowest">
								<p class="font-label-caps text-on-surface text-[10px]">DÉPART</p>
								<p class="text-body-sm">29/07/2024</p>
							</div>
						</div>
						<div class="p-sm cursor-pointer hover:bg-surface-container-lowest relative">
							<p class="font-label-caps text-on-surface text-[10px]">VOYAGEURS</p>
							<p class="text-body-sm">2 voyageurs</p>
							<span class="material-symbols-outlined absolute right-sm top-1/2 -translate-y-1/2">expand_more</span>
						</div>
					</div>
					<button onclick="window.location.href='{{ path('confirmReservation', {'id': property.id}) }}'"  class="w-full bg-primary-container text-on-primary-container py-md rounded-lg font-headline-sm text-center shadow-md hover:opacity-90 transition-all active:scale-[0.98]">
						Réserver
					</button>
					<p class="text-center text-body-sm text-on-surface-variant">Aucun montant ne vous sera débité pour le moment</p>
					<div class="flex flex-col gap-sm py-md">
						<div class="flex justify-between text-body-md">
							<span class="underline">1 250 € x 7 nuits</span>
							<span>8 750 €</span>
						</div>
						<div class="flex justify-between text-body-md">
							<span class="underline">Frais de ménage</span>
							<span>250 €</span>
						</div>
						<div class="flex justify-between text-body-md">
							<span class="underline">Frais de service Airbnb</span>
							<span>1 260 €</span>
						</div>
					</div>
					<div class="border-t border-outline-variant pt-md flex justify-between font-label-bold text-lg">
						<span>Total</span>
						<span>10 260 €</span>
					</div>
				</div>
				<div class="mt-lg flex items-center justify-center gap-md border border-outline-variant rounded-lg p-md text-on-surface-variant">
					<span class="material-symbols-outlined text-[24px]">flag</span>
					<span class="font-label-bold underline">Signaler cette annonce</span>
				</div>
			</aside>
		</div>
		<!-- Reviews Section -->
		<section class="py-xxl border-t border-outline-variant mt-xxl">
			<div class="flex items-center gap-sm mb-xxl">
				<span class="material-symbols-outlined text-[32px]" style="font-variation-settings: 'FILL' 1;">star</span>
				<h2 class="font-headline-md text-headline-md text-on-surface">4,92 · 128 commentaires</h2>
			</div>
			<div
				class="grid grid-cols-1 md:grid-cols-2 gap-x-xxl gap-y-xl">
				<!-- Review 1 -->
				<div class="flex flex-col gap-md">
					<div class="flex items-center gap-md">
						<div class="w-12 h-12 rounded-full overflow-hidden">
							<img class="w-full h-full object-cover" data-alt="A portrait of a smiling young woman named Sophie, looking directly into the camera with a joyful expression. The background is a soft, sun-drenched coastal cafe, emphasizing a positive travel experience. The lighting is warm and natural, aligning with the premium brand aesthetic." src="https://lh3.googleusercontent.com/aida/AP1WRLsvWlxKCHA9P8l9OFGszIp79b5SlT9vLioxgEQ7yjP-ykcyQkn0umACKsdCvi6SasutfrC2okRCLB5qPaDNWqLDGF7vuCb0Pc2cdXOvZcvmYapD5NX1QNMmluY21eD8CpQ7yfenl8ehXCm5u25h19BBLHJeZpAbvVzzUpqJK3eO8XNdK3mSyzNPu4pvIX9yX2yEh08YO1IaW3ChmKsnckL10a0okaGeLF_7tYTMHx2dGYfbdREM9T5Kvmg0"/>
						</div>
						<div>
							<p class="font-label-bold text-on-surface">Sophie</p>
							<p class="text-body-sm text-on-surface-variant">Juin 2024 · Voyage en famille</p>
						</div>
					</div>
					<p class="text-body-md text-on-surface leading-relaxed">
						La villa est encore plus belle que sur les photos. La vue sur la mer depuis la piscine est tout simplement magique. Elena est une hôte exceptionnelle, très réactive et pleine de bons conseils pour les restaurants locaux.
					</p>
				</div>
				<!-- Review 2 -->
				<div class="flex flex-col gap-md">
					<div class="flex items-center gap-md">
						<div class="w-12 h-12 rounded-full overflow-hidden">
							<img class="w-full h-full object-cover" data-alt="A portrait of a middle-aged man with a professional yet relaxed appearance, Marc, smiling warmly. He is outdoors with soft greenery in the background, lit by bright daylight that conveys a sense of high-quality vacation vibes and reliability." src="https://lh3.googleusercontent.com/aida/AP1WRLt0_Au7hth0HWx5SNav1t3ufP5ImLK8JXOr3lZzl9Oxu-RtepNaSvyL1s7BTjbrs9sZZ4difcLDvXmESNCmLfx49DuNto1TGWUhARgiqJAkxDZOI6O5MWVdg2c7MM7L6LhHqNFkjKdE8z3Od_RCSbZKTu5GFWn7D6YUvNsu1ONbW8qhE1alnuTatxxKfA2M_r4-YkY6IrHJzGRo03VHgf0jNZMAxWKF1T3BzTQz_1A5Gsj70oTsInkW5I0"/>
						</div>
						<div>
							<p class="font-label-bold text-on-surface">Marc</p>
							<p class="text-body-sm text-on-surface-variant">Mai 2024</p>
						</div>
					</div>
					<p class="text-body-md text-on-surface leading-relaxed">
						Un séjour inoubliable. Le design de la maison est très bien pensé, très spacieux et lumineux. L'équipement de la cuisine est professionnel, ce qui a rendu nos dîners en terrasse fantastiques. Nous reviendrons !
					</p>
				</div>
			</div>
			<button class="mt-xxl border border-on-surface px-lg py-md rounded-lg font-label-bold hover:bg-surface-container-low transition-colors">
				Afficher les 128 commentaires
			</button>
		</section>

	</main>
{% endblock %}
