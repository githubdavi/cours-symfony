{% extends "/layout/base.html.twig" %}

{% block sideBar %}
	{% include 'admin/sideBar.html.twig' %}
{% endblock %}
{% block content %}

	<main
		class="max-w-container-max mx-auto px-lg py-xl pb-32">
		<!-- Header Section -->
		<div class="flex flex-col md:flex-row md:items-center justify-between gap-md mb-xxl">
			<div>
				<h1 class="font-headline-md text-headline-md text-on-surface mb-xs">Gestion des hébergements</h1>
				<p class="text-on-surface-variant font-body-sm text-body-sm">Visualisez et gérez l'ensemble de votre parc immobilier en temps réel.</p>
			</div>
			<a href="{{ path('app_property_new') }}" class="bg-primary text-on-primary font-label-bold text-label-bold px-lg py-sm rounded-xl shadow-sm hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-xs h-12">
				<span class="material-symbols-outlined" data-icon="add">add</span>
				Ajouter un nouveau logement
			</a>
		</div>
		<!-- Filters & Tools Bar -->
		<div class="flex flex-wrap items-center gap-md mb-lg">
			<div class="relative flex-grow max-w-md">
				<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline" data-icon="search">search</span>
				<input class="w-full pl-12 pr-4 py-3 bg-surface border border-outline-variant rounded-full focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Rechercher par titre ou ID..." type="text"/>
			</div>
			<button class="flex items-center gap-xs px-md py-3 border border-outline-variant rounded-full font-label-bold text-label-bold text-on-surface hover:bg-surface-container-low transition-colors">
				<span class="material-symbols-outlined" data-icon="filter_list">filter_list</span>
				Filtres
			</button>
		</div>
		<!-- Property Table/Grid (Responsive Table) -->
		<div class="bg-surface rounded-xl border border-outline-variant overflow-hidden shadow-sm">
			<div class="overflow-x-auto">
				<table class="w-full text-left border-collapse">
					<thead>
						<tr class="bg-surface-container-low text-on-surface-variant border-b border-outline-variant">
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider">Hébergement</th>
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider">Type &amp; ID</th>
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider">Statut</th>
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider text-center">Voyageurs</th>
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider text-right">Prix / Nuit</th>
							<th class="px-lg py-md font-label-caps text-label-caps uppercase tracking-wider text-right">Actions</th>
						</tr>
					</thead>
					<tbody
						class="divide-y divide-outline-variant">
						<!-- Property Row 1 -->
						{% for property in properties %}
							<tr class="hover:bg-surface-container-lowest transition-colors group">
								<td class="px-lg py-lg">
									<div class="flex items-center gap-md">
										<div class="w-16 h-12 rounded-lg overflow-hidden flex-shrink-0 bg-surface-container-highest">
											<img alt="Villa sur la falaise" class="w-full h-full object-cover" data-alt="A luxurious modern villa perched on a Mediterranean cliffside overlooking the azure ocean. The architecture features clean lines, expansive glass walls, and a minimalist white stone finish. The scene is bathed in golden hour sunlight, creating long soft shadows and a warm, prestigious atmosphere. Professional architectural photography style." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDj8lR6hluQZq6eDr_8CZm6BRSTJ8FAbTCWWEW24hYWYparhOs1a-0aSOgMOq9xKvs5ToKkboPmPKdjp13LQmdgl92zpeYc1aCGhNz_ZxzFLYudpxFeglmkKcJezVJW4mdRp7QNLfUX5s781Uq2taBSpLNR6YoyFJqFFnbjYu5hDXpoU02oSuMY7_OpSH0e8OQCTzClcrrsIoCsjP82-Q0ubSRc7DGEw8j6GGtIinMn-xOBxonegt2RVwgMSmirrAhd9wQbiICZdQkr"/>
										</div>
										<div class="font-label-bold text-on-surface">{{ property.title }}
										</div>
									</div>
								</td>
								<td class="px-lg py-lg">
									<div class="flex flex-col">
										<span class="text-on-surface-variant font-body-sm text-body-sm">{{ property.propertyType }}
											Villa entière</span>
										<span class="text-outline font-label-caps text-[10px] tracking-tight uppercase">ID: PROP-82910</span>
									</div>
								</td>
								<td class="px-lg py-lg">
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-tertiary-container/10 text-tertiary">
										<span class="w-1.5 h-1.5 rounded-full bg-tertiary mr-1.5"></span>
										{{ property.status }}
										Publié
									</span>
								</td>
								<td class="px-lg py-lg text-center font-body-md text-body-md text-on-surface-variant">
									{{ property.maxGuests }}
									6
								</td>
								<td class="px-lg py-lg text-right font-label-bold text-on-surface">
									{{ property.pricePerNight }}
									€
								</td>
								<td class="px-lg py-lg text-right">
									<div class="flex justify-end gap-xs opacity-0 group-hover:opacity-100 transition-opacity">
										<a href="{{ path('app_property_show', {'id': property.id}) }}" class="p-2 hover:bg-surface-container-low rounded-lg text-on-surface-variant flex items-center gap-1 font-label-bold text-sm">
											<span class="material-symbols-outlined text-[18px]" data-icon="visibility">visibility</span>
											Voir
										</a>
										<a href="{{ path('app_property_edit', {'id': property.id}) }}" class="p-2 hover:bg-surface-container-low rounded-lg text-primary flex items-center gap-1 font-label-bold text-sm">
											<span class="material-symbols-outlined text-[18px]" data-icon="edit">edit</span>
											Modifier
										</a>
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
			<div class="px-lg py-md border-t border-outline-variant flex items-center justify-between bg-surface-container-lowest">
				<span class="text-body-sm text-on-surface-variant font-body-sm">Affichage de 1 à 3 sur 12 propriétés</span>
				<div class="flex items-center gap-xs">
					<button class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors disabled:opacity-30" disabled="">
						<span class="material-symbols-outlined" data-icon="chevron_left">chevron_left</span>
					</button>
					<button class="w-10 h-10 flex items-center justify-center rounded-lg border border-primary bg-primary text-on-primary font-label-bold text-sm">1</button>
					<button class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors font-label-bold text-sm">2</button>
					<button class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors">
						<span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
					</button>
				</div>
			</div>
		</div>
		<!-- Bento Stats Section for Admin -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-lg mt-xxl">
			<div class="bg-surface p-lg rounded-xl border border-outline-variant shadow-sm flex flex-col gap-sm">
				<div class="flex items-center justify-between">
					<span class="text-on-surface-variant font-label-bold">Revenu Total (Mois)</span>
					<span class="material-symbols-outlined text-primary" data-icon="payments">payments</span>
				</div>
				<div class="text-headline-sm font-bold text-on-surface">12,450.00 €</div>
				<div class="text-tertiary font-body-sm flex items-center gap-1">
					<span class="material-symbols-outlined text-sm" data-icon="trending_up">trending_up</span>
					+12% vs mois dernier
				</div>
			</div>
			<div class="bg-surface p-lg rounded-xl border border-outline-variant shadow-sm flex flex-col gap-sm">
				<div class="flex items-center justify-between">
					<span class="text-on-surface-variant font-label-bold">Taux d'occupation</span>
					<span class="material-symbols-outlined text-primary" data-icon="calendar_month">calendar_month</span>
				</div>
				<div class="text-headline-sm font-bold text-on-surface">84.2%</div>
				<div class="text-on-surface-variant font-body-sm flex items-center gap-1">
					<span class="material-symbols-outlined text-sm" data-icon="info">info</span>
					3 hébergements complets
				</div>
			</div>
			<div class="bg-surface p-lg rounded-xl border border-outline-variant shadow-sm flex flex-col gap-sm">
				<div class="flex items-center justify-between">
					<span class="text-on-surface-variant font-label-bold">Notes moyennes</span>
					<span class="material-symbols-outlined text-primary" data-icon="star">star</span>
				</div>
				<div class="text-headline-sm font-bold text-on-surface">4.92 / 5</div>
				<div class="text-on-surface-variant font-body-sm flex items-center gap-1">
					<span class="material-symbols-outlined text-sm" data-icon="reviews">reviews</span>
					Basé sur 128 avis
				</div>
			</div>
		</div>
	</main>
{% endblock %}
