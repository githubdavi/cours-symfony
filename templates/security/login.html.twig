{% extends 'base.html.twig' %}

{% block body %}
	<body
		class="bg-surface-container-low font-body-md text-on-surface">

		<!-- TopNavBar -->
		<header class="fixed top-0 w-full z-50 bg-surface dark:bg-surface-dim border-b border-outline-variant dark:border-outline shadow-sm h-20">
			<div class="flex justify-between items-center h-full px-margin-mobile md:px-lg max-w-container-max mx-auto">
				<div class="flex items-center gap-xs">
					<span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">travel_explore</span>
					<span class="font-headline-sm text-headline-sm text-primary dark:text-primary-fixed-dim font-bold">Airbnb</span>
				</div>
				<div class="flex items-center gap-md">
					<button class="p-base rounded-full hover:bg-surface-container-low transition-colors duration-200 cursor-pointer active:scale-95 flex items-center">
						<span class="material-symbols-outlined text-on-surface-variant">language</span>
					</button>
					<button class="flex items-center gap-xs p-xs pr-sm border border-outline-variant rounded-full hover:bg-surface-container-low transition-colors duration-200 cursor-pointer active:scale-95">
						<span class="material-symbols-outlined text-on-surface-variant p-xs">menu</span>
						<span class="material-symbols-outlined text-on-surface-variant text-3xl" style="font-variation-settings: 'FILL' 1;">account_circle</span>
					</button>
				</div>
			</div>
		</header>

		<main class="min-h-screen pt-20 flex items-center justify-center px-margin-mobile">
			<div
				class="w-full max-w-[568px] bg-white rounded-xl auth-card-shadow overflow-hidden border border-outline-variant">

				<!-- Card Header -->
				<div class="px-lg py-md border-b border-outline-variant text-center">
					<h1 class="font-headline-sm text-headline-sm text-on-surface">Connexion</h1>
				</div>

				<!-- Card Body -->
				<div
					class="p-lg">

					{# ── Erreur d'authentification ── #}
					{% if error %}
						<div class="mb-md p-md bg-red-50 border border-red-200 rounded-lg text-red-700 font-body-sm text-body-sm flex items-center gap-sm">
							<span class="material-symbols-outlined text-red-500 text-lg">error</span>
							{{ error.messageKey|trans(error.messageData, 'security') }}
						</div>
					{% endif %}

					<form class="space-y-lg" action="{{ path('login') }}" method="post">
						<div class="space-y-sm">
							<h2 class="font-headline-sm text-headline-sm">Bienvenue sur Traveler's Sanctuary</h2>

							<!-- Input Group -->
							<div class="border border-outline rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-primary transition-all">
								<div class="relative px-md py-sm border-b border-outline">
									<label class="block font-label-caps text-label-caps text-on-surface-variant uppercase" for="email">
										Adresse e-mail
									</label<inputclass="blockw-fullbg-transparentborder-nonep-0font-body-mdfocus:ring-0"id="email"name="email"type="email"placeholder="nom@exemple.com"autocomplete="email"requiredautofocus>
								</div>
								<div class="relative px-md py-sm">
									<label class="block font-label-caps text-label-caps text-on-surface-variant uppercase" for="password">
										Mot de passe
									</label>
									<div class="flex items-center">
										<input class="block w-full bg-transparent border-none p-0 font-body-md focus:ring-0" id="password" name="password" type="password" placeholder="••••••••" autocomplete="current-password" required>
										<button type="button" id="togglePassword" class="text-label-bold font-label-bold text-on-surface-variant hover:text-on-surface underline ml-sm shrink-0">
											Afficher
										</button>
									</div>
								</div>
							</div>
						</div>

						{# ── Token CSRF (obligatoire) ── #}
						<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

						<p class="font-body-sm text-body-sm text-on-surface-variant">
							Vos données sont protégées conformément à notre
							<a class="font-label-bold underline" href="#">Politique de confidentialité</a>.
						</p>

						<button class="w-full h-[48px] bg-primary text-on-primary rounded-lg font-label-bold text-lg hover:brightness-110 active:scale-95 transition-all flex items-center justify-center" type="submit">
							Continuer
						</button>
					</form>

					<!-- Separator -->
					<div class="my-lg flex items-center gap-md">
						<div class="flex-1 h-[1px] bg-outline-variant"></div>
						<span class="font-body-sm text-on-surface-variant">ou</span>
						<div class="flex-1 h-[1px] bg-outline-variant"></div>
					</div>

					<!-- Social Methods -->
					<div class="space-y-sm">
						<button class="w-full h-[48px] border border-on-surface rounded-lg px-md flex items-center hover:bg-surface-container-low transition-colors active:scale-98">
							<span class="material-symbols-outlined text-blue-600 mr-auto">face_nod</span>
							<span class="flex-1 text-center font-label-bold">Continuer avec Facebook</span>
							<span class="w-6"></span>
						</button>
						<button class="w-full h-[48px] border border-on-surface rounded-lg px-md flex items-center hover:bg-surface-container-low transition-colors active:scale-98">
							<span class="mr-auto">
								<svg class="w-5 h-5" viewbox="0 0 24 24">
									<path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
									<path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
									<path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
									<path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
								</svg>
							</span>
							<span class="flex-1 text-center font-label-bold">Continuer avec Google</span>
							<span class="w-6"></span>
						</button>
						<button class="w-full h-[48px] border border-on-surface rounded-lg px-md flex items-center hover:bg-surface-container-low transition-colors active:scale-98">
							<span class="material-symbols-outlined text-black mr-auto" style="font-variation-settings: 'FILL' 1;">apps</span>
							<span class="flex-1 text-center font-label-bold">Continuer avec Apple</span>
							<span class="w-6"></span>
						</button>
						<a href="{{ path('register') }}" class="w-full h-[48px] border border-on-surface rounded-lg px-md flex items-center hover:bg-surface-container-low transition-colors active:scale-98">
							<span class="material-symbols-outlined text-on-surface-variant mr-auto">mail</span>
							<span class="flex-1 text-center font-label-bold">Pas de compte ? S'inscrire</span>
							<span class="w-6"></span>
						</a>
					</div>

				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="w-full py-lg bg-surface-container-lowest dark:bg-surface-container-high border-t border-outline-variant dark:border-outline">
			<div class="flex flex-col md:flex-row justify-between items-center px-margin-mobile md:px-lg max-w-container-max mx-auto gap-md">
				<div class="flex flex-col md:flex-row items-center gap-md">
					<span class="font-label-bold text-label-bold text-on-surface">© 2024 Airbnb, Inc. All rights reserved.</span>
					<div class="flex gap-md">
						<a class="font-body-sm text-body-sm text-on-surface-variant hover:underline hover:text-primary transition-colors" href="#">Privacy</a>
						<a class="font-body-sm text-body-sm text-on-surface-variant hover:underline hover:text-primary transition-colors" href="#">Terms</a>
						<a class="font-body-sm text-body-sm text-on-surface-variant hover:underline hover:text-primary transition-colors" href="#">Sitemap</a>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Toggle password visibility
const passwordInput = document.getElementById('password');
const toggleBtn = document.getElementById('togglePassword');
if (toggleBtn && passwordInput) {
toggleBtn.addEventListener('click', () => {
const isPassword = passwordInput.type === 'password';
passwordInput.type = isPassword ? 'text' : 'password';
toggleBtn.textContent = isPassword ? 'Masquer' : 'Afficher';
});
}
		</script>

	</body>
{% endblock %}
